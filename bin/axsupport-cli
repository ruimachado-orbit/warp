    42|            query = console.input("\n[bold cyan]You:[/bold cyan] ")
    43|            if query.lower() in ("exit", "quit", "q"):
    44|                console.print("[yellow]Goodbye![/yellow]")
    45|                break
    46|
    47|            if not query.strip():
