#!/usr/bin/env python3
"""
Warp CLI compatibility wrapper.

The packaged console entrypoint is ``warp=cli:main``. This script remains for
existing local workflows that call ``bin/axsupport-cli`` directly.
"""
import sys
from pathlib import Path

# Add src to path for direct source-tree execution.
SCRIPT_DIR = Path(__file__).parent
sys.path.insert(0, str(SCRIPT_DIR.parent / "src"))

from cli import main


if __name__ == "__main__":
    main()