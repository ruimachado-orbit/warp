# Warp — environment template
# Copy to .env. Do not commit real values.

# LLM providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
LLM_PROVIDER_ORDER=anthropic,openai,openrouter
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.2

# Zendesk
ZENDESK_SUBDOMAIN=
ZENDESK_EMAIL=
ZENDESK_API_TOKEN=

# Intercom
INTERCOM_ACCESS_TOKEN=

# Freshdesk
FRESHDESK_DOMAIN=
FRESHDESK_API_KEY=

# Salesforce Service Cloud
SALESFORCE_INSTANCE_URL=
SALESFORCE_ACCESS_TOKEN=

# HubSpot Service Hub
HUBSPOT_ACCESS_TOKEN=

# Jira Service Management
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_SERVICE_PROJECT_KEY=SUP

# Front
FRONT_API_TOKEN=

# Help Scout
HELPSCOUT_ACCESS_TOKEN=

# Collaboration / docs
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
NOTION_TOKEN=

# Runtime
WARP_HTTP_TIMEOUT=30
