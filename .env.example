# Axsupport — Environment Configuration
# Copy this file to .env and fill in your API keys


SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
NOTION_TOKEN=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# LLM Provider Priority (comma-separated)
LLM_PROVIDER_ORDER=anthropic,openai,openrouter

# Optional: Override default LLM settings
# LLM_MAX_TOKENS=4096
# LLM_TEMPERATURE=0.7