# Warp — environment template
# Copy to .env. Do not commit real values.

# LLM providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-v4-flash
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=Warp
# Codex uses official `codex app-server --listen stdio://`.
# CODEX_APP_SERVER_URL is a transport URL, not an OpenAI-compatible /v1 endpoint.
CODEX_APP_SERVER_URL=stdio://
CODEX_APP_SERVER_COMMAND=codex
CODEX_APP_SERVER_MODEL=gpt-5.5
CODEX_APP_SERVER_TIMEOUT=300
CODEX_APP_SERVER_CWD=
CODEX_APP_SERVER_SANDBOX=read-only
CODEX_APP_SERVER_APPROVAL_POLICY=never
# Provider fallback order. Legacy alias LLM_PROVIDERS is also accepted.
LLM_PROVIDER_ORDER=anthropic,openai,openrouter,codex_app_server
LLM_MAX_TOKENS=16384
LLM_TEMPERATURE=0.2

# Zendesk
ZENDESK_SUBDOMAIN=
ZENDESK_EMAIL=
ZENDESK_API_TOKEN=

# Intercom
INTERCOM_ACCESS_TOKEN=

# Freshdesk
FRESHDESK_DOMAIN=
FRESHDESK_API_KEY=

# Salesforce Service Cloud
SALESFORCE_INSTANCE_URL=
SALESFORCE_ACCESS_TOKEN=

# HubSpot Service Hub
HUBSPOT_ACCESS_TOKEN=

# Jira Service Management
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_SERVICE_PROJECT_KEY=SUP

# Front
FRONT_API_TOKEN=

# Help Scout
HELPSCOUT_ACCESS_TOKEN=

# Collaboration / docs
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
NOTION_TOKEN=

# Runtime
# Optional config path override. Legacy alias AXSUPPORT_CONFIG is also accepted.
# WARP_CONFIG=/path/to/config.yaml
# Legacy alias AXSUPPORT_HTTP_TIMEOUT is also accepted.
WARP_HTTP_TIMEOUT=30

# Website deployment (SAM/CloudFront)
SITE_HOSTNAME=warp.maiolabs.ai
ACM_CERTIFICATE_ARN=arn:aws:acm:us-east-1:857119674988:certificate/2824f1c9-0a05-472d-b64b-204a29f7381f
ALLOWED_ORIGIN=https://warp.maiolabs.ai
RESEND_API_KEY=
RESEND_FROM=hello@maiolabs.ai
RESEND_TO=hello@maiolabs.ai
CLOUDFORMATION_STACK_NAME=warp-site
AWS_REGION=eu-west-1
